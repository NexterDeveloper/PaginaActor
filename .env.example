# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin password hash (generate with: node scripts/hash-password.js TU_CONTRASEÑA)
ADMIN_PASSWORD_HASH=$2a$12$...

# JWT secret for admin session cookie
ADMIN_JWT_SECRET=your-random-secret-at-least-32-chars
